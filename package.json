    "check": "tsc --noEmit",
    "dev": "tsx src/index.tsx"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^6",
    "react": "^19"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/react": "^19",
    "tsup": "^8.3.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
