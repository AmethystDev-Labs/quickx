{
  "name": "@amethyst-labs/quickx",
  "version": "2.0.1",
  "description": "Codex profile switcher with a Commander CLI and Ink TUI",
  "keywords": [
    "codex",
    "cli",
    "ink",
    "react",
    "openai"
  ],
  "homepage": "https://github.com/AmethystDev-Labs/quickx",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/AmethystDev-Labs/quickx.git"
  },
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "bin": "./dist/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
